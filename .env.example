# RescuNav - Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===================================
# Fireworks AI API Key
# ===================================
# Get your API key from: https://fireworks.ai/account/api-keys
# 1. Sign up at https://fireworks.ai/
# 2. Go to Account → API Keys
# 3. Create new API key
# 4. Copy and paste below
FIREWORKS_API_KEY=your_fireworks_api_key_here

# ===================================
# MongoDB Atlas Connection
# ===================================
# Get your connection string from: https://cloud.mongodb.com/
# 1. Sign up at https://www.mongodb.com/cloud/atlas/register
# 2. Create a free cluster (M0)
# 3. Click "Connect" → "Connect your application"
# 4. Copy the connection string
# 5. Replace <password> with your actual password
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database name (default: building_analysis)
MONGODB_DATABASE=building_analysis

# Collection name for video analysis (default: video_analysis)
MONGODB_COLLECTION=video_analysis

# ===================================
# Optional Configuration
# ===================================
# Flask debug mode (set to False in production)
# FLASK_DEBUG=True

# Flask port (default: 5000)
# FLASK_PORT=5000

# Simulation parameters
# DEFAULT_ITERATIONS=10
# DEFAULT_AGENTS=3
