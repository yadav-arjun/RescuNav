# IDE and Editor Files
# ===================================
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# ===================================
# Operating System Files
# ===================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ===================================
