# Python
# ===================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# ===================================
# Virtual Environment
# ===================================
venv/
ENV/
env/
.venv

# ===================================
# Database Files
# ===================================
*.db
*.sqlite
*.sqlite3

# ===================================
# Large Media Files
# ===================================
*.mp4
*.avi
*.mov
*.mkv
*.flv
*.wmv

# Specific large files
main.mp4
jsonl_training/bench11.mp4

# Large 3D files (optional - uncomment if you want to exclude)
# *.vtk
# *.stl
# *.ply

